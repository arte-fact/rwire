# Copy to .env and adjust. The app loads .env at startup; real environment
# variables already set take precedence over values here. Never commit .env.

# --- Auth gate (login page) ---------------------------------------------------
# Set BOTH (non-empty) to require a login for the page and the WebSocket.
# Leave unset/empty for open access (local dev only). Run behind TLS.
AUTH_USER=
AUTH_PASSWORD=

# --- Network ------------------------------------------------------------------
# Address to bind. Default: 0.0.0.0:7778 (all interfaces, reverse-proxied).
BIND_ADDR=0.0.0.0:7778

# --- Hardware -----------------------------------------------------------------
# GPU backend selection: auto | rocm | nvidia | none. Default: auto.
GPU_BACKEND=auto

# --- Paths --------------------------------------------------------------------
# Directory scanned for local models (.gguf, ...). Default: ./models.
MODELS_DIR=./models

# Directory where saved node profiles live. Default: ./profiles.
NODE_PROFILES_DIR=./profiles

# Directory for per-node engine logs. Default: system temp dir (/tmp).
#NODE_LOG_DIR=/tmp

# --- Engine binaries ----------------------------------------------------------
# Each launchable (engine, backend) reads its own executable path from a *_BIN
# var and an optional LD_LIBRARY_PATH prefix from *_LIBS. An unset *_BIN means
# that combination is "not configured" and won't launch. Values below are this
# host's verified builds — adjust to your machine.
#
# llama.cpp
LLAMACPP_HIP_BIN=../llama.cpp/build-master/bin/llama-server
LLAMACPP_HIP_LIBS=../llama.cpp/build-master/bin:/opt/rocm-host/lib
LLAMACPP_CUDA_BIN=../llama.cpp/build-cuda/bin/llama-server
LLAMACPP_CUDA_LIBS=../llama.cpp/build-cuda/bin:/usr/local/cuda/lib64
#LLAMACPP_CPU_BIN=
#LLAMACPP_CPU_LIBS=
#
# flambeau
FLAMBEAU_HIP_BIN=../flambeau/target/release/flambeau
FLAMBEAU_HIP_LIBS=/opt/rocm-host/lib
#FLAMBEAU_CUDA_BIN=
#FLAMBEAU_CUDA_LIBS=
#
# vLLM
#VLLM_CUDA_BIN=
#VLLM_CUDA_LIBS=
#VLLM_CPU_BIN=
#VLLM_CPU_LIBS=

# --- ROCm (AMD / HIP) ---------------------------------------------------------
# ROCm root for HIP engines + rocBLAS env. Default: /opt/rocm. On gfx906 (MI50)
# the stock /opt/rocm dropped the rocBLAS Tensile kernels and SIGABRTs — point
# this at a build that still ships them (e.g. /opt/rocm-host, ROCm 7.1.1).
ROCM_OVERRIDE=/opt/rocm-host
# Optional explicit rocm-smi path. Otherwise tried in order: PATH,
# ${ROCM_OVERRIDE}/bin/rocm-smi, /opt/rocm/bin/rocm-smi, then any /opt/rocm*.
#ROCM_SMI=
